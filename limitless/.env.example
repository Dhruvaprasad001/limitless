# PostgreSQL asyncpg DSN — update host/port/credentials as needed
DATABASE_URL=postgresql+asyncpg://limitless:limitless@localhost:5432/limitless

# OpenAI
OPENAI_API_KEY=sk-...

# Model configuration
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
RETRIEVAL_TOP_K=10

# Logging
LOG_LEVEL=INFO
