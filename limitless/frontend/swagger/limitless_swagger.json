          },
          "page": {
            "type": "integer",
            "title": "Page"
          },
          "limit": {
            "type": "integer",
            "title": "Limit"
          },
          "items": {
            "items": {
              "$ref": "#/components/schemas/MessageResponse"
            },
            "type": "array",
            "title": "Items"
          }
        },
        "type": "object",
        "required": [
          "total",
          "page",
          "limit",
          "items"
        ],
        "title": "MessageListResponse"
      },
      "MessageResponse": {
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "title": "Id"
          },
          "tenant_id": {
            "type": "string",
            "format": "uuid",
            "title": "Tenant Id"
          },
          "user_id": {
            "type": "string",
            "format": "uuid",
            "title": "User Id"
          },
          "user_name": {
            "type": "string",
            "title": "User Name"
          },
          "content": {
            "type": "string",
            "title": "Content"
          },
          "event_time": {
            "type": "string",
            "format": "date-time",
            "title": "Event Time"
          },
          "ingested_at": {
            "type": "string",
            "format": "date-time",
            "title": "Ingested At"
          }
        },
        "type": "object",
        "required": [
          "id",
          "tenant_id",
          "user_id",
          "user_name",
          "content",
          "event_time",
          "ingested_at"
        ],
        "title": "MessageResponse"
      },
      "QueryRequest": {
        "properties": {
          "question": {
            "type": "string",
            "title": "Question"
          }
        },
        "type": "object",
        "required": [
          "question"
        ],
        "title": "QueryRequest"
      },
      "QueryResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "supporting_message_ids": {
            "items": {
              "type": "string",
              "format": "uuid"
            },
            "type": "array",
            "title": "Supporting Message Ids"
          },
          "supporting_timestamps": {
            "items": {
              "type": "string",
              "format": "date-time"
            },
            "type": "array",
            "title": "Supporting Timestamps"
          },
          "supporting_user_names": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Supporting User Names"
          },
          "supporting_messages": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Supporting Messages"
          },
          "query_plan": {
            "additionalProperties": true,
            "type": "object",
            "title": "Query Plan"
          }
        },
        "type": "object",
        "required": [
          "answer",
          "supporting_message_ids",
          "supporting_timestamps",
          "supporting_user_names",
          "supporting_messages",
          "query_plan"
        ],
        "title": "QueryResponse"
      },
      "TenantCreate": {
        "properties": {
          "name": {
            "type": "string",
